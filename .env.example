PORT=3004

# Tailscale Funnel public URL (e.g. https://aurora.tail1234.ts.net)
TUNNEL_PUBLIC_URL=

# MAC address of the Google Nest Hub — used to resolve current IP via ARP at runtime
CAST_DEVICE_MAC=30:fd:38:0e:3b:ba
CAST_APP_ID=

# Cast reconnect delay on disconnect (ms)
CAST_RECONNECT_DELAY_MS=5000

# logger-pi
LOGGER_PI_URL=http://127.0.0.1:4000
LOGGER_PI_SERVICE_NAME=nesthub-pi
